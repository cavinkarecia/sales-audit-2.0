# Copy to backend/.env for local testing (never commit real secrets)
PORT=3000
NODE_ENV=development
DATABASE_URL=postgresql://user:password@localhost:5432/sentinel
SESSION_SECRET=change-this-to-a-long-random-string
APP_PASSWORD=your-dashboard-password
# Optional for local dev only — production uses the browser "AI Key" chip instead
# ANTHROPIC_API_KEY=sk-ant-api03-...
# Use current Sonnet (do NOT use retired claude-sonnet-4-20250514)
ANTHROPIC_MODEL=claude-sonnet-4-6

# Expense validation tuning (optional)
OCR_CONFIDENCE_THRESHOLD=0.72
CLAIM_TIME_WINDOW_MINUTES=10
BILL_MAX_AGE_DAYS=3

# WhatsApp PJP deviation notices
# Required on Render so auditor response links use the correct host
PUBLIC_BASE_URL=https://sales-audit-2-0-2.onrender.com

# Optional — auto-send to auditors WhatsApp group via Twilio (otherwise opens wa.me for manual paste)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# Group JID or number, e.g. whatsapp:+120363xxxxx@g.us
WHATSAPP_NOTIFY_TO=
